# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must never be committed. Generate strong, unique secrets per environment.
#
#   Generate a session secret:   openssl rand -hex 32
#   Generate a DB password:      openssl rand -base64 24

# --- PostgreSQL ---------------------------------------------------------
POSTGRES_USER=lms
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=lms

# --- Backend ------------------------------------------------------------
# Server-side session secret (>= 16 chars; use 32+ random bytes).
SESSION_SECRET=change-me-with-openssl-rand-hex-32
# How long an issued session remains valid.
SESSION_TTL_HOURS=12
# Set to "false" only for local plain-HTTP testing. Keep "true" in production
# so the session cookie carries the Secure attribute.
COOKIE_SECURE=true

# --- Seed admin (created on first run if it does not exist) --------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-admin-password

# --- Misc ---------------------------------------------------------------
# Host port the frontend (nginx) is published on.
FRONTEND_PORT=8080
RUST_LOG=lms_backend=info,tower_http=info,sqlx=warn
