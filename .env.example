# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must never be committed. Generate strong, unique secrets per environment.
#
#   Generate a session secret:   openssl rand -hex 32
#   Generate a DB password:      openssl rand -base64 24

# --- PostgreSQL ---------------------------------------------------------
POSTGRES_USER=lms
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=lms

# --- Backend ------------------------------------------------------------
# Server-side session secret (>= 16 chars; use 32+ random bytes).
SESSION_SECRET=change-me-with-openssl-rand-hex-32
# How long an issued session remains valid.
SESSION_TTL_HOURS=12
# Set to "false" only for local plain-HTTP testing. Keep "true" in production
# so the session cookie carries the Secure attribute.
COOKIE_SECURE=true

# --- Seed admin (created on first run if it does not exist) --------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-admin-password

# --- Single sign-on (OpenID Connect) — optional -------------------------
# Leave all OIDC_* blank to run with password login only. To enable SSO with
# any OIDC provider (Google, Microsoft Entra ID, Okta, Auth0, Keycloak, ...),
# register an application with the provider and fill these in. The redirect URL
# must be registered with the provider and point at the callback route below.
#
#   OIDC_ISSUER_URL=https://accounts.google.com
#   OIDC_REDIRECT_URL=https://lms.example.com/api/auth/sso/callback
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=
# Role assigned to users created on their first SSO login (admin|manager|learner).
OIDC_DEFAULT_ROLE=learner
# Optional: restrict SSO sign-in to a single email domain (e.g. example.com).
OIDC_ALLOWED_EMAIL_DOMAIN=
# Where the browser lands after a successful SSO login.
POST_LOGIN_REDIRECT=/

# --- Misc ---------------------------------------------------------------
# Host port the frontend (nginx) is published on.
FRONTEND_PORT=8080
RUST_LOG=lms_backend=info,tower_http=info,sqlx=warn
